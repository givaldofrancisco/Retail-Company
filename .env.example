# LLM provider: gemini, ollama, or auto
# - gemini: force Gemini
# - ollama: force local Ollama
# - auto: try Gemini first, then Ollama
LLM_PROVIDER=gemini

# Gemini API key (if LLM_PROVIDER=gemini or auto)
GOOGLE_API_KEY=your_google_ai_api_key

# Ollama local endpoint (if LLM_PROVIDER=ollama or auto fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: explicitly set BigQuery project for billing/job context.
# If omitted, BigQuery client will use ADC default project.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Optional: override model
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_MODEL=qwen2.5

# Optional debug logging (true/false)
DEBUG=false
